/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    graft configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
Overview:
- Default pipeline parameters for neurobridge.
- Runtime execution should usually be controlled via:
  - `conf/local/nextflow.config` for profiles / resources / containers
  - `assets/params.stage1.yaml` or `assets/params.stage2.yaml` for user-tunable analysis parameters
- Values defined here act as sensible defaults and can be overridden at runtime.

Notes:
- Container / executor settings are defined in `profiles {}` below.
- Analysis-specific parameters here are intended as defaults, not fixed requirements.

*/

params {
  input           = null
  pairs           = null
  outdir          = "results"
  pybin           = "python3"
  rbin            = "Rscript"
  plink           = "plink"
  tag_prefix      = "eur_humdef"
  ldak_os         = "ldak6.1.linux"
  clump_score_col = "conj_fdr"
}

process {

  // QC_GWAS
  withName: 'QC_GWAS' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_QC:QC_GWAS' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'PREP_LDSC_INPUT:QC_GWAS' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_LDSC:PREP_LDSC_INPUT:QC_GWAS' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  // ADD_NEFF
  withName: 'ADD_NEFF' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_QC:ADD_NEFF' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_LDSC:PREP_ALIGNED_LDSC_INPUT:ALIGN_GWAS' {
    publishDir = [
      path: { "${params.outdir}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  withName: 'PREP_LDSC_INPUT:ADD_NEFF' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_LDSC:PREP_LDSC_INPUT:ADD_NEFF' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  // LDSC
  withName: 'LDSC' {
    publishDir = [
      path: { "${params.outdir}/LDSC/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_LDSC:LDSC' {
    publishDir = [
      path: { "${params.outdir}/LDSC/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  // HDL
  withName: 'HDL' {
    publishDir = [
      path: { "${params.outdir}/HDL/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_HDL:HDL' {
    publishDir = [
      path: { "${params.outdir}/HDL/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_HDL:PREP_HDL_INPUT:QC_GWAS' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_HDL:PREP_HDL_INPUT:ADD_NEFF' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  // SumHer
  withName: 'TAGGING' {
    publishDir = [
      path: { "${params.outdir}/SumHer/tagging" },
      mode: 'copy'
    ]
  }

  withName: 'H2' {
    publishDir = [
      path: { "${params.outdir}/SumHer/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'RG' {
    publishDir = [
      path: { "${params.outdir}/SumHer/rg/${meta.trait1}_${meta.trait2}" },
      mode: 'copy',
      saveAs: { name ->
        name.startsWith('res/') ? name.replaceFirst(/^res\//, '') : name
      }
    ]
  }

  withName: 'STAGE1_SUMHER:PREP_SUMHER_INPUT:QC_GWAS' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_SUMHER:PREP_SUMHER_INPUT:ADD_NEFF' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_SUMHER:SUMHER_RUN:TAGGING' {
    publishDir = [
      path: { "${params.outdir}/SumHer/tagging" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_SUMHER:SUMHER_RUN:H2' {
    publishDir = [
      path: { "${params.outdir}/SumHer/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_SUMHER:SUMHER_RUN:RG' {
    publishDir = [
      path: { "${params.outdir}/SumHer/rg/${meta.trait1}_${meta.trait2}" },
      mode: 'copy',
      saveAs: { name ->
        name.startsWith('res/') ? name.replaceFirst(/^res\//, '') : name
      }
    ]
  }

  // conjFDR
  withName: 'CONJFDR_DATA_PREP' {
    publishDir = [
      path: { "${params.outdir}/ConjFDR/ready/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  withName: 'CONJFDR' {
    publishDir = [
      path: { "${params.outdir}/ConjFDR/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_CONJFDR:PREP_CONJFDR_INPUT:QC_GWAS' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_CONJFDR:PREP_CONJFDR_INPUT:ADD_NEFF' {
    publishDir = [
      path: { "${params.outdir}/QC/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_CONJFDR:CONJFDR_DATA_PREP' {
    publishDir = [
      path: { "${params.outdir}/ConjFDR/ready/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_CONJFDR:CONJFDR' {
    publishDir = [
      path: { "${params.outdir}/ConjFDR/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }
  
  // LAVA
  withName: 'LAVA' {
    publishDir = [
      path: { "${params.outdir}/LAVA/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_LAVA:LAVA' {
      publishDir = [
      path: { "${params.outdir}/LAVA/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  withName: 'LAVA_HITS_TO_LOCI' {
      publishDir = [
      path: { "${params.outdir}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  withName: 'STAGE1_LAVA:LAVA_HITS_TO_LOCI' {
      publishDir = [
      path: { "${params.outdir}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  withName: 'STAGE1_DEF_LOCI:PREP_DEFINED_LOCI_INPUT:LD_CLUMP' {
    publishDir = [
      path: { "${params.outdir}/LD_clumping" },
      mode: 'copy'
    ]
  }

  withName: 'DEFINE_LOCI' {
    publishDir = [
      path: { "${params.outdir}/Defined_loci" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_DEF_LOCI:PREP_DEFINED_LOCI_INPUT:DEFINE_LOCI' {
    publishDir = [
      path: { "${params.outdir}/Defined_loci" },
      mode: 'copy'
    ]
  }

  withName: 'GWAS_COLOCALISATION' {
    publishDir = [
      path: { "${params.outdir}/GWAS_Colocalisation/${meta.source}/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_GWAS_COLOC:GWAS_COLOCALISATION' {
    publishDir = [
      path: { "${params.outdir}/GWAS_Colocalisation/${meta.source}/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  withName: 'SUSIE_OVERLAP_MAP' {
    publishDir = [
      path: { "${params.outdir}/SuSiE/${meta.source}/${meta.pair}/${meta.locus}/L${params.susie_L}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  withName: 'STAGE1_SUSIE:SUSIE_OVERLAP_MAP' {
    publishDir = [
      path: { "${params.outdir}/SuSiE/${meta.source}/${meta.pair}/${meta.locus}/L${params.susie_L}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  withName: 'STAGE1_SUSIE:SUSIE_OVERLAP_MAP' {
    maxForks = 1
  }
}













process {
  withName: 'MAGMA' {
    publishDir = [
      path: { "${params.outdir}/MAGMA/${meta.id}" },
      mode: 'copy'
    ]
  }
}


process {
  withName: 'FUMA_PREP' {
    publishDir = [
      path: { "${params.outdir}/FUMA/prep/${meta.pair}" },
      mode: 'copy'
    ]
  }
}

process {
  withName: 'FUMA_POST_DIRS' {
    publishDir = [
      path: { "${params.outdir}/FUMA/post/${meta.pair}/${meta.trait}" },
      mode: 'copy'
    ]
  }
}


// env configs
profiles {
  local {
    process.executor = 'local'
    docker.enabled = false
    conda.enabled = false
  }

  // Docker (local)
  docker {
    process.executor = 'local'
    docker.enabled = true
    conda.enabled = false
    process.container = 'neurobridge:1'
    process.stageInMode = 'copy'
    params.ldak_os = 'ldak6.1.linux' 
    // docker.userEmulation  = true
  }

  // singularity (Slurm / Falcon)
  /* Create a Docker repo
  > slap neurobridge image
  > pull with apptainer from HPC
  */
  singularity {
    process.executor = 'slurm'
    docker.enabled = false
    singularity.enabled = true
    singularity.autoMounts = true
    process.container = params.container ?: "${projectDir}/neurobridge_1.sif"
  }
}

// ------------ ------ ------------ //
// ----------- VERSIONS ----------- //
// ------------ ------ ------------ //

manifest {
  name = 'nf-core/neurobridge'
  version = '1.0.0'
}
