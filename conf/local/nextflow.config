  }

  withName: 'STAGE1_SUSIE:SUSIE_OVERLAP_MAP' {
    publishDir = [
      path: { "${params.outdir}/SuSiE/${meta.source}/${meta.pair}/${meta.locus}/L${params.susie_L}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  withName: 'STAGE1_SUSIE:SUSIE_OVERLAP_MAP' {
    maxForks = 1
  }

  /* MAGMA
  withName: 'STAGE1_MAGMA:MAGMA' {
    publishDir = [
      path: { "${params.outdir}/MAGMA/${}"}
    ]
  }
  */
  withName: 'STAGE1_MAGMA:MAGMA' {
    publishDir = [
      path: { "${params.outdir}/MAGMA/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'FUMA_PREP' {
    publishDir = [
      path: { "${params.outdir}/FUMA/prep/${meta.source}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_FUMA:PREP_FUMA_INPUT:FUMA_PREP' {
    publishDir = [
