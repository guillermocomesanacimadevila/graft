      mode: 'copy'
    ]
  }

  withName: 'STAGE1_TWOSAMPLEMR:TWOSAMPLEMR_PREP:ADD_NEFF' {
    publishDir = [
      path: { "${params.outdir}/TwoSampleMR/QCed/${meta.id}" },
      mode: 'copy'
    ]
  }

  withName: 'STAGE1_TWOSAMPLEMR:TWOSAMPLEMR' {
    publishDir = [
      path: { "${params.outdir}/TwoSampleMR/${meta.trait1}_${meta.trait2}" },
      mode: 'copy'
    ]
  }

  // TARGET GENES 
  withName: 'STAGE1_TARGET_GENES:TARGET_GENES_PREP:MAP_TARGET_GENES' {
    publishDir = [
      path: { "${params.outdir}/TargetGenes/${meta.trait1}_${meta.trait2}/${source}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  withName: 'STAGE1_QTL_MANIFEST:QTL_MANIFEST_PREP:GEN_QTL_MANIFEST' {
    publishDir = [
      path: { "${params.qtl_manifest_out}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  // SMR - QTL STUFF

  // QTL preprocessing (CRITICAL — OOM prone)
  withName: 'STAGE1_SMR:SMR_BULK:PREP_BULK_QTL_FOR_SMR' {
  publishDir = [
    path: { "${params.outdir}/SMR/bulk/prep/${meta.id}" },
    mode: 'copy',
    overwrite: true
  ]
}

  withName: 'STAGE1_SMR:SMR_SC:PREP_SC_QTL_FOR_SMR' {
    publishDir = [
      path: { "${params.outdir}/SMR/sc/prep/${meta.id}/${meta.cell_type}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  withName: 'STAGE1_SMR:SMR_BULK:BULK_SMR_HEIDI' {
    publishDir = [
      path: { "${params.outdir}/SMR/bulk/runs/${gwas_meta.id}_${qtl_meta.id}_${qtl_meta.qtl_modality}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  withName: 'STAGE1_SMR:SMR_SC:SC_SMR_HEIDI' {
    publishDir = [
      path: { "${params.outdir}/SMR/sc/runs/${gwas_meta.id}_${qtl_meta.id}_${qtl_meta.cell_type}_${qtl_meta.qtl_modality}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  withName: 'STAGE1_SMR:SMR_BULK:GRAB_BULK_SMR_HITS' {
    publishDir = [
      path: { "${params.outdir}/SMR_hits/bulk/${gwas_meta.id}_${qtl_meta.id}_${qtl_meta.qtl_modality}" },
      mode: 'copy',
      overwrite: true
    ]
  }

  withName: 'STAGE1_SMR:SMR_SC:GRAB_SC_SMR_HITS' {
    publishDir = [
      path: { "${params.outdir}/SMR_hits/sc/${gwas_meta.id}_${qtl_meta.id}_${qtl_meta.cell_type}_${qtl_meta.qtl_modality}" },
      mode: 'copy',
      overwrite: true
    ]
  }
}

process {
  maxForks = 2
  // cpus = 16 - need to make a loop to check whether low / mid / high cpu request
  // memory = 8.GB
  // container = "link/to/docker_image"
}

// env configs
profiles {
  local {
    process.executor = 'local'
    docker.enabled = false
    conda.enabled = false
  }

  // Docker 
  docker {
    process.executor = 'local'
    docker.enabled = true
    conda.enabled = false
    process.container = 'graft:1'
    process.stageInMode = 'copy' // process.stageInMode = 'symlink'
    // keep copy but parse outputs into respective SQL .dbs in GCP datalake
    params.ldak_os = 'ldak6.1.linux' 
    // docker.userEmulation  = true
    docker.runOptions = "--platform linux/amd64"
  }

  // singularity (Slurm / Falcon)
  /* Create a Docker repo
  > slap graft image
  > pull with apptainer from HPC
  */
  singularity {
    process.executor = 'slurm'
    docker.enabled = false
    singularity.enabled = true
    singularity.autoMounts = true
    process.stageInMode = 'symlink'
    /*
    > Pull Docker config from pre-built image
    */
    process.container = params.container ?: "${projectDir}/neurobridge_1.sif"
    // docker.runOptions = "-v ${projectDir}/ref/SMR/smr:/usr/local/bin/smr"
  }
}

// ------------ ------ ------------ //
// ----------- VERSIONS ----------- //
// ------------ ------ ------------ //

manifest {
  name = 'nf-core/graft'
  version = '1.0.0'
}