/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    graft configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
Overview:
- Default pipeline parameters for graft.
- Runtime execution should usually be controlled via:
  - `conf/local/nextflow.config` for profiles / resources / containers
  - `assets/params.stage1.yaml` or `assets/params.stage2.yaml` for user-tunable analysis parameters
- Values defined here act as sensible defaults and can be overridden at runtime.

Notes:
- Container / executor settings are defined in `profiles {}` below.
- Analysis-specific parameters here are intended as defaults, not fixed requirements.

*/

process {
  executor = 'slurm'
  stageInMode = 'symlink'
  errorStrategy = 'retry'
  maxRetries = 1

  cpus = {
    if (params.cpus) {
      return params.cpus
    } else {
      return 4
    }
  }

  memory = {
    if (params.memory) {
      return params.memory
    } else {
      return '16 GB'
    }
  }

  time = {
    if (params.time_hrs) {
      return "${params.time_hrs}h"
    } else {
      return '24h'
    }
  }

  maxForks = {
    if (params.max_forks) {
      return params.max_forks
    } else {
      return 20
    }
  }

  container = {
    if (params.container) {
      return params.container
    } else {
      return "${projectDir}/env/graft_1.0.0.sif"
    }
  }
}

executor {
  queueSize = {
    if (params.queue_size) {
      return params.queue_size
    } else {
      return 50
    }
  }

  submitRateLimit = '10 sec'
}

singularity {
  enabled = true
  autoMounts = true
  // cacheDir = "${projectDir}/env/singularity_cache"
}

docker {
  enabled = false
}

conda {
  enabled = false
}
