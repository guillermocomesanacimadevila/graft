/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    graft configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
Overview:
- Default pipeline parameters for graft.
- Runtime execution should usually be controlled via:
  - `conf/local/nextflow.config` for profiles / resources / containers
  - `assets/params.stage1.yaml` or `assets/params.stage2.yaml` for user-tunable analysis parameters
- Values defined here act as sensible defaults and can be overridden at runtime.

Notes:
- Container / executor settings are defined in `profiles {}` below.
- Analysis-specific parameters here are intended as defaults, not fixed requirements.

*/

process {
  executor = 'slurm'
  stageInMode = 'symlink'
  errorStrategy = 'retry'
  maxRetries = 1

  if (params.cpus) {
    cpus = params.cpus
  } else {
    cpus = 4
  }

  if (params.memory) {
    memory = params.memory
  } else {
    memory = '16 GB'
  }

  if (params.time_hrs) {
    time = "${params.time_hrs}h"
  } else {
    time = '24h'
  }

  if (params.max_forks) {
    maxForks = params.max_forks
  } else {
    maxForks = 20
  }

  if (params.container) {
    container = params.container
  } else {
    container = "${projectDir}/env/neurobridge_1.sif"
  }
}

executor {
  if (params.queue_size) {
    queueSize = params.queue_size
  } else {
    queueSize = 50
  }

  submitRateLimit = '10 sec'
}

singularity {
  enabled = true
  autoMounts = true
  cacheDir = "${projectDir}/env/singularity_cache"
}

docker {
  enabled = false
}

conda {
  enabled = false
}